---
import Base from "../layouts/Base.astro";
const title = "Give • Fountain of Grace International";
const description = "Partner with the vision of Fountain of Grace International.";
---
<Base {title} {description} canonical="https://fountaingrace.org/give">
  <div class="card">
    <h1>Give</h1>
    <p>Your generosity advances the Gospel and serves families in our city. Thank you.</p>
    <h3>Bank Transfer (South Africa)</h3>
    <p><em>Replace with church banking details or PayFast link.</em></p>
    <p><a class="btn" href="#" aria-disabled="true" onclick="return false;">Add PayFast/Stripe Link</a></p>
    <p style="color:var(--muted)">Need help? <a href="mailto:fountaingraceinternational@gmail.com">Contact us</a>.</p>
  </div>
</Base>
