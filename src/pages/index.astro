---
import Base from "../layouts/Base.astro";
---

<Base title="Fountain of Grace International">
  <section style="text-align:center; margin-bottom:2.5rem;">
    <h1 style="font-size:2.2rem; font-weight:800; color:var(--fg-blue-800); margin:0 0 1rem;">
      A Place to Encounter Jesus and Be Restored
    </h1>
    <p style="max-width:600px;margin:0 auto 1.5rem;color:var(--muted);font-size:1.1rem;">
      We gather to worship, learn the Word, and love our city.
    </p>

    <p style="margin:.5rem 0;color:var(--muted);font-size:.95rem;">
      <strong>Service:</strong> Sundays 9:00–11:00<br/>
      <strong>Address:</strong> 323 B Danie Theron Street, Pretoria North<br/>
      <strong>Contact:</strong>
      <a href="mailto:info@fountaingrace.org">info@fountaingrace.org</a> ·
      <a href="https://wa.me/27752592555" target="_blank" rel="noopener">WhatsApp</a>
    </p>

    <div style="display:flex;flex-wrap:wrap;gap:.8rem;justify-content:center;margin-top:1.5rem;">
      <a href="/give/" class="btn btn--brand">Give Online</a>
      <a href="/prayer/" class="btn btn--ghost">Request Prayer</a>
      <a href="/plan-a-visit/" class="btn btn--ghost">Plan a Visit</a>
      <a href="/blog/" class="btn btn--ghost">Read Messages</a>
    </div>
  </section>

  <!-- Carousel -->
  <section class="carousel-container">
    <div class="carousel">
      <div class="slides">
        <img src="/FatherandSon.webp" alt="Father and Son" />
        <img src="/First lady.webp" alt="First Lady" />
        <img src="/Worship.webp" alt="Worship" />
        <img src="/ZaalKids.webp" alt="Kids Ministry" />
      </div>
    </div>
  </section>

  <style>
    /* Carousel container */
    .carousel-container{
      position:relative;
      max-width:900px;
      margin:0 auto 3rem;
      border-radius:var(--radius);
      overflow:hidden;
      box-shadow:var(--shadow);
    }

    .carousel{
      width:100%;
      overflow:hidden;
    }

    .slides{
      display:flex;
      width:400%;
      animation:slide 20s infinite;
    }

    .slides img{
      width:100%;
      height:auto;
      object-fit:cover;
      flex-shrink:0;
    }

    @keyframes slide{
      0%{transform:translateX(0)}
      20%{transform:translateX(0)}
      25%{transform:translateX(-100%)}
      45%{transform:translateX(-100%)}
      50%{transform:translateX(-200%)}
      70%{transform:translateX(-200%)}
      75%{transform:translateX(-300%)}
      95%{transform:translateX(-300%)}
      100%{transform:translateX(0)}
    }

    /* Mobile responsiveness */
    @media(max-width:600px){
      h1{font-size:1.7rem}
      p{font-size:1rem}
      .slides img{height:auto}
    }
  </style>
</Base>
