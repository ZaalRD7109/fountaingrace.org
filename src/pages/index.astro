---
import Base from "../layouts/Base.astro";
---

<Base title="Fountain of Grace International">
  <!-- Hero Section -->
  <section style="text-align:center; margin-bottom:2.5rem;">
    <h1 style="font-size:2.2rem; font-weight:800; color:#2A5C8F; margin:0 0 1rem;">
      A Place to Encounter Jesus and Be Restored
    </h1>
    <p style="max-width:600px;margin:0 auto 1.5rem;color:#444;font-size:1.1rem;">
      We gather to worship, learn the Word, and love our city.
    </p>

    <p style="margin:.5rem 0;color:#555;font-size:.95rem;">
      <strong>Service:</strong> Sundays 9:00–11:00<br/>
      <strong>Address:</strong> 323 B Danie Theron Street, Pretoria North<br/>
      <strong>Contact:</strong>
      <a href="mailto:info@fountaingrace.org">info@fountaingrace.org</a> ·
      <a href="https://wa.me/27752592555" target="_blank" rel="noopener">WhatsApp</a>
    </p>

    <div style="display:flex;flex-wrap:wrap;gap:.8rem;justify-content:center;margin-top:1.5rem;">
      <a href="/give/" class="btn btn--brand">Give Online</a>
      <a href="/prayer/" class="btn btn--ghost">Request Prayer</a>
      <a href="/plan-a-visit/" class="btn btn--ghost">Plan a Visit</a>
      <a href="/blog/" class="btn btn--ghost">Read Messages</a>
    </div>
  </section>

  <!-- Placeholder for Photos (to be added later) -->
  <section style="text-align:center; margin:3rem 0;">
    <h2 style="font-size:1.6rem; color:#2A5C8F;">Our Family in Action</h2>
    <p style="color:#666; font-size:1rem;">(Photos will be added here later)</p>
  </section>

  <!-- Floating Social Icons -->
  <div class="floating-social">
    <!-- Facebook -->
    <a href="https://facebook.com/YourChurchPage" target="_blank" rel="noopener" class="icon fb" aria-label="Facebook">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="20" height="20" fill="white"><path d="M279.14 288l14.22-92.66h-88.91V127.41c0-25.35 12.42-50.06 52.24-50.06H293V6.26S277.4 0 262.7 0c-73.14 0-121.3 44.38-121.3 124.72V195.3H86.41V288h55v224h91.63V288z"/></svg>
    </a>

    <!-- YouTube -->
    <a href="https://youtube.com/YourChannel" target="_blank" rel="noopener" class="icon yt" aria-label="YouTube">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" width="22" height="22" fill="white"><path d="M549.7 124.1c-6.3-23.7-24.9-42.3-48.6-48.6C465.1 64 288 64 288 64s-177.1 0-213.1 11.5c-23.7 6.3-42.3 24.9-48.6 48.6C16.8 160.1 16.8 256 16.8 256s0 95.9 9.5 131.9c6.3 23.7 24.9 42.3 48.6 48.6C110.9 448 288 448 288 448s177.1 0 213.1-11.5c23.7-6.3 42.3-24.9 48.6-48.6 9.5-36 9.5-131.9 9.5-131.9s0-95.9-9.5-131.9zM232 334.9V177.1l142.8 78.9L232 334.9z"/></svg>
    </a>

    <!-- TikTok -->
    <a href="https://tiktok.com/@YourChurchTikTok" target="_blank" rel="noopener" class="icon tt" aria-label="TikTok">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="22" height="22" fill="white"><path d="M448,209.6a210.1,210.1,0,0,1-122.77-39.25v141.9a116.15,116.15,0,1,1-99.08-114.9v84.62a58.08,58.08,0,1,0,41,55.71V0h80.8A129.33,129.33,0,0,0,448,128.54Z"/></svg>
    </a>
  </div>

  <style>
    .btn {
      padding: 10px 18px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
      transition: all 0.3s ease;
    }
    .btn--brand {
      background: #2A5C8F; /* navy */
      color: #fff;
    }
    .btn--brand:hover { background: #244a72; }
    .btn--ghost {
      background: transparent;
      border: 2px solid #2A5C8F;
      color: #2A5C8F;
    }
    .btn--ghost:hover {
      background: #2A5C8F;
      color: #fff;
    }

    /* Floating Social Icons */
    .floating-social {
      position: fixed;
      top: 40%;
      right: 20px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      z-index: 1000;
    }
    .floating-social .icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      text-decoration: none;
      box-shadow: 0 0 15px rgba(0,0,0,0.4);
      transition: all 0.3s ease;
    }
    .floating-social .fb {
      background: #1877F2;
      box-shadow: 0 0 15px #1877F2;
    }
    .floating-social .fb:hover {
      box-shadow: 0 0 25px #1877F2;
      transform: scale(1.1);
    }
    .floating-social .yt {
      background: #FF0000;
      box-shadow: 0 0 15px #FF0000;
    }
    .floating-social .yt:hover {
      box-shadow: 0 0 25px #FF0000;
      transform: scale(1.1);
    }
    .floating-social .tt {
      background: #010101;
      box-shadow: 0 0 15px #25F4EE;
    }
    .floating-social .tt:hover {
      box-shadow: 0 0 25px #FE2C55;
      transform: scale(1.1);
    }
  </style>
</Base>
