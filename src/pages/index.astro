---
import Base from "../layouts/Base.astro";
const title = "Fountain of Grace International • Pretoria North";
const description = "Sundays 9:00–11:00 • 323 B Danie Theron Street, Pretoria North • You're welcome here.";
---

<Base {title} {description} canonical="https://fountaingrace.org/">
  <section class="hero grid grid-2">
    <!-- Left: message + CTAs -->
    <div class="card">
      <h1 style="font-size:clamp(28px,3.6vw,44px); margin:0 0 10px;">A place to encounter Jesus and be restored.</h1>
      <p style="color:var(--muted); font-size:18px;">Join us this Sunday. We gather to worship, learn the Word, and love our city.</p>
      <ul style="line-height:1.9; margin-top:10px">
        <li><strong>Service:</strong> Sundays 9:00–11:00</li>
        <li><strong>Address:</strong> 323 B Danie Theron Street, Pretoria North</li>
        <li><strong>Contact:</strong> <a href="mailto:info@fountaingrace.org">info@fountaingrace.org</a> · <a href="https://wa.me/27752592555" target="_blank" rel="noopener">WhatsApp us</a></li>
      </ul>

      <!-- Primary soul-winning CTAs -->
      <div style="margin-top:18px; display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/prayer" class="btn" style="background:#1e90ff; color:white;">Request Prayer</a>
        <a href="/contact" class="btn">Plan a Visit</a>
        <a href="/give" class="btn" style="background:#ffd166; color:#222;">Give Online</a>
        <a href="/blog" class="btn" style="background:#2dd4bf; color:#063;">Read Messages</a>
      </div>
      <p style="margin-top:12px; color:var(--muted); font-size:14px;">
        Our mission is simple: <em>make fishers of men</em> (Matthew 4:19). Every button above is a next step toward Jesus.
      </p>
    </div>

    <!-- Right: smaller map so message stays central -->
    <div class="card">
      <div style="position:relative; height:300px; border-radius:12px; overflow:hidden;">
        <iframe
          title="Map"
          src="https://www.google.com/maps?q=323%20B%20Danie%20Theron%20Street,%20Pretoria%20North&output=embed"
          style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"
          loading="lazy" allowfullscreen></iframe>
      </div>
      <div style="margin-top:10px; font-size:14px;">
        <a href="https://www.google.com/maps/dir/?api=1&destination=323%20B%20Danie%20Theron%20Street%2C%20Pretoria%20North" target="_blank" rel="noopener">Get Directions</a>
      </div>
    </div>
  </section>

  <!-- Auto-sliding photo gallery -->
  <section style="margin-top:18px;">
    <div class="gallery card">
      <div class="slides" id="slides">
        <img src="/FatherandSon.jpg" alt="Father and Son at FGI" />
        <img src="/First%20lady.jpg" alt="First Lady at FGI" />
        <img src="/Worship.jpg" alt="Worship at FGI" />
        <img src="/ZaalKids.jpg" alt="Zaal Kids at FGI" />
      </div>
      <button class="arrow left" id="prev" aria-label="Previous slide">‹</button>
      <button class="arrow right" id="next" aria-label="Next slide">›</button>
      <div class="dots" id="dots"></div>
    </div>

    <script is:inline>
      // simple, dependency-free slider
      const slides = document.getElementById('slides');
      const imgs = [...slides.querySelectorAll('img')];
      const dotsWrap = document.getElementById('dots');
      let i = 0, timer;

      // build dots
      imgs.forEach((_, idx) => {
        const d = document.createElement('div');
        d.className = 'dot' + (idx===0 ? ' active' : '');
        d.addEventListener('click', () => go(idx, true));
        dotsWrap.appendChild(d);
      });

      const dots = [...dotsWrap.children];

      function render() {
        slides.style.transform = `translateX(-${i * 100}%)`;
        dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
      }
      function go(n, user=false) {
        i = (n + imgs.length) % imgs.length;
        render();
        if (user) reset();
      }
      function next(){ go(i+1); }
      function prev(){ go(i-1); }
      function reset(){ clearInterval(timer); timer = setInterval(next, 5000); }

      document.getElementById('next').addEventListener('click', () => go(i+1, true));
      document.getElementById('prev').addEventListener('click', () => go(i-1, true));

      // init
      slides.style.width = `${imgs.length * 100}%`;
      imgs.forEach(img => img.style.width = `${100 / imgs.length}%`);
      render();
      reset();
    </script>
  </section>

  <section class="grid grid-3" style="margin-top:18px;">
    <div class="card"><h3>Teaching</h3><p>Spirit-filled preaching grounded in the Word, with practical application.</p></div>
    <div class="card"><h3>Community</h3><p>We’re family. Small, real, growing. There’s a seat for you.</p></div>
    <div class="card"><h3>Mission</h3><p>We exist to restore dignity and hope in Pretoria and beyond.</p></div>
  </section>
</Base>
