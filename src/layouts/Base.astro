import SocialBubbles from "../components/SocialBubbles.astro";
---
// src/layouts/Base.astro
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}
const {
  title = "Fountain of Grace International",
  description = "A place to encounter Jesus and be restored. We gather to worship, learn the Word, and love our city.",
  canonical = "https://fountaingrace.org/",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicons / Brand -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <!-- Removed og:image (no big photo) -->

    <!-- ✅ Facebook Domain Verification -->
    <meta name="facebook-domain-verification" content="tp6wubugatwfvaPlcrz2sjw6pp987c" />

    <!-- ✅ Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-15FK8BTR4B"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-15FK8BTR4B');
    </script>

    <style>
      :root{
        --fg-blue-50:#f4f9ff;
        --fg-blue-100:#e9f3ff;
        --fg-blue-200:#cfe6ff;
        --fg-blue-400:#3a8bdc;
        --fg-blue-500:#227bcf;
        --fg-blue-600:#1865ac;
        --fg-blue-800:#0e3f6d;
        --fg-gold:#e3b22e;
        --bg:var(--fg-blue-50);
        --text:#0b1b2b;
        --muted:#5a6b7a;
        --card:#ffffff;
        --ring:rgba(34,123,207,.25);
        --shadow:0 10px 30px rgba(16,42,67,.08);
        --radius:14px;
      }
      *{box-sizing:border-box}
      html,body{height:100%}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Helvetica Neue,Arial,'Noto Sans',sans-serif;color:var(--text);background:var(--bg);line-height:1.5}
      a{color:var(--fg-blue-600);text-decoration:none}
      a:hover{text-decoration:underline}
      .wrap{max-width:1120px;margin-inline:auto;padding:16px}
      @media(min-width:768px){.wrap{padding:24px}}
      main{min-height:60vh}
      .site-header{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.92);backdrop-filter:saturate(1.2) blur(10px);border-bottom:1px solid rgba(14,63,109,.06);}
      .nav{display:flex;align-items:center;gap:16px;}
      .brand{display:flex;align-items:center;gap:10px;font-weight:700;color:var(--fg-blue-800);white-space:nowrap;}
      .brand img{width:40px;height:40px;object-fit:contain;}
      .spacer{flex:1}
      .menu{display:flex;gap:16px;align-items:center}
      .menu a{font-weight:600;color:var(--fg-blue-600)}
      .btn{display:inline-flex;align-items:center;justify-content:center;padding:.6rem .9rem;border-radius:999px;font-weight:700;box-shadow:var(--shadow);}
      .btn--brand{background:var(--fg-blue-500);color:#fff}
      .btn--brand:hover{background:var(--fg-blue-600)}
      footer{border-top:1px solid rgba(14,63,109,.08);background:#fff;}
      .footer-grid{display:grid;gap:18px;}
      @media(min-width:768px){.footer-grid{grid-template-columns:1.2fr 1fr 1fr}}
      .muted{color:var(--muted)}
      .footer-h{font-weight:800;color:var(--fg-blue-800);margin:0 0 .5rem}
      iframe.map-embed{width:100%;height:200px;border:0;border-radius:var(--radius);}
    </style>
  </head>
  <SocialBubbles />
<body>
    <!-- HEADER -->
    <header class="site-header">
      <div class="wrap nav">
        <a href="/" class="brand" aria-label="Fountain of Grace International home">
          <img src="/Fountain of Grace International Logo 2.webp" alt="" />
          <span>Fountain of Grace International</span>
        </a>
        <div class="spacer"></div>
        <nav class="menu" aria-label="Main">
          <a href="/blog/">Blog</a>
          <a href="/events/">Events</a>
          <a href="/prayer/">Prayer</a>
          <a class="btn btn--brand" href="/give/">Give</a>
        </nav>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <main id="content" class="wrap">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer>
      <div class="wrap footer-grid">
        <section>
          <h3 class="footer-h">Fountain of Grace International</h3>
          <p class="muted">A place to encounter Jesus and be restored.</p>
          <p class="muted">Sundays 9:00–11:00</p>
          <p class="muted">323 B Danie Theron Street, Pretoria North</p>
          <p class="muted"><strong>Contact:</strong>
            <a href="mailto:info@fountaingrace.org">info@fountaingrace.org</a>
            &nbsp;·&nbsp;
            <a href="https://wa.me/27752592555" target="_blank">WhatsApp</a>
          </p>
          <!-- ✅ Small Google Map -->
          <iframe class="map-embed" src="https://www.google.com/maps/embed?pb=!1m18!..." allowfullscreen loading="lazy"></iframe>
        </section>

        <section>
          <h4 class="footer-h">Next Steps</h4>
          <p><a href="/plan-a-visit/">Plan a Visit</a></p>
          <p><a href="/prayer/">Request Prayer</a></p>
          <p><a href="/blog/">Read Messages</a></p>
        </section>

        <section>
          <h4 class="footer-h">Follow</h4>
          <p><a href="https://facebook.com/Fountainofgraceministries" target="_blank">Facebook</a></p>
          <p><a href="https://youtube.com/@fountainofgraceptanorth" target="_blank">YouTube</a></p>
          <p><a href="https://www.tiktok.com/@ricardodzaal" target="_blank">TikTok</a></p>
        </section>
      </div>
      <div class="wrap" style="padding:8px 0 28px;">
        <small class="muted">© {new Date().getFullYear()} Fountain of Grace International. All rights reserved.</small>
      </div>
    </footer>
  </body>
</html>
