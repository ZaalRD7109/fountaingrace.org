import SocialBubbles from "../components/SocialBubbles.astro";
---
const {
  title = "Fountain of Grace International",
  description = "A Christ-centered community in Pretoria North.",
  canonical
} = Astro.props;
---

<html lang="en">
  <head>
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Favicon / icons (uses your real logo) -->
    <link rel="icon" href="/Fountain%20of%20Grace%20International%20Logo%202.png" />
    <link rel="apple-touch-icon" href="/Fountain%20of%20Grace%20International%20Logo%202.png" />
    <meta name="theme-color" content="#1ea0ff" />

    <style>
      :root{
        --bg:#0b1220;        /* page background */
        --card:#0f172a;      /* card background */
        --text:#e6edf3;      /* text color */
        --muted:#9fb0c0;     /* muted text */
        --accent:#d4a017;    /* FGI gold */
        --accent2:#1ea0ff;   /* FGI blue */
      }
      *{box-sizing:border-box}
      body{margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, 'Helvetica Neue', Arial; background:var(--bg); color:var(--text);}
      a{color:var(--accent2); text-decoration:none}
      a:hover{text-decoration:underline}

      header{position:sticky; top:0; z-index:50; backdrop-filter:saturate(1.2) blur(6px); background:#0b1220cc; border-bottom:1px solid #1f2a44}
      .wrap{max-width:1100px; margin:0 auto; padding:16px}
      nav{display:flex; gap:16px; align-items:center; justify-content:space-between}
      .brand{display:flex; gap:10px; align-items:center; font-weight:700; letter-spacing:0.3px}
      .brand img{height:28px; width:auto; display:block}
      .navlinks a{margin-left:14px; font-weight:600; opacity:.95}
      .navlinks a:hover{opacity:1}
      .hero{padding:56px 16px 24px}

      .card{background:var(--card); border:1px solid #1f2a44; border-radius:16px; padding:20px; box-shadow:0 6px 20px rgba(0,0,0,.25)}
      .btn{display:inline-block; padding:12px 16px; border-radius:12px; background:var(--accent); color:#222; font-weight:800}
      .btn:hover{filter:brightness(1.05)}
      .grid{display:grid; gap:16px}
      @media(min-width:800px){ .grid-3{grid-template-columns:repeat(3,1fr)} .grid-2{grid-template-columns:repeat(2,1fr)} }

      /* gallery styles */
      .gallery{position:relative; overflow:hidden; border-radius:16px; border:1px solid #1f2a44}
      .slides{display:flex; transition:transform .5s ease; width:100%}
      .slides img{width:100%; height:360px; object-fit:cover; display:block}
      .arrow{position:absolute; top:50%; transform:translateY(-50%); background:#0009; color:#fff; border:none; padding:10px 12px; border-radius:12px; cursor:pointer}
      .arrow:hover{background:#000c}
      .arrow.left{left:10px}
      .arrow.right{right:10px}
      .dots{position:absolute; left:0; right:0; bottom:10px; display:flex; gap:8px; justify-content:center}
      .dot{width:10px; height:10px; border-radius:50%; background:#ffffff55; border:1px solid #ffffff88}
      .dot.active{background:#fff}
    </style>
  </head>

  <body>
    <header>
      <div class="wrap">
        <nav>
          <div class="brand">
            <img src="/Fountain%20of%20Grace%20International%20Logo%202.png" alt="Fountain of Grace International" />
            <a href="/"><span>Fountain of Grace International</span></a>
          </div>
          <div class="navlinks">
            <a href="/blog">Blog</a>
            <a href="/events">Events</a>
            <a href="/prayer">Prayer</a>
            <a href="/give" class="btn">Give</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer>
      <div class="wrap" style="display:flex; flex-wrap:wrap; gap:16px; align-items:center; justify-content:space-between; border-top:1px solid #1f2a44; margin-top:56px; padding:16px 0;">
        <div>© {new Date().getFullYear()} Fountain of Grace International • Pretoria North</div>
        <div><a href="/contact">Contact</a> · <a href="/privacy">Privacy</a></div>
      </div>
    </footer>
 <SocialBubbles />
 </body>
</html>
