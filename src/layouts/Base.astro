---
const { title = "Fountain of Grace International", description = "A Christ-centered community in Pretoria North.", canonical } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonical && <link rel="canonical" href={canonical} />}
    <style>
      :root{--bg:#0b1220;--card:#0f172a;--text:#e6edf3;--muted:#9fb0c0;--accent:#b8860b;--accent2:#1e90ff;}
      *{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Cantarell,Noto Sans,'Helvetica Neue',Arial,'Apple Color Emoji','Segoe UI Emoji';background:var(--bg);color:var(--text);}
      a{color:var(--accent2);text-decoration:none}
      a:hover{text-decoration:underline}
      header{position:sticky;top:0;backdrop-filter:saturate(1.2) blur(6px);background:#0b1220cc;border-bottom:1px solid #1f2a44}
      .wrap{max-width:1100px;margin:0 auto;padding:16px}
      nav{display:flex;gap:16px;align-items:center;justify-content:space-between}
      .brand{display:flex;gap:10px;align-items:center;font-weight:700;letter-spacing:.3px}
      .navlinks a{margin-left:14px;font-weight:500}
      .hero{padding:56px 16px 24px}
      .card{background:var(--card);border:1px solid #1f2a44;border-radius:16px;padding:20px;box-shadow:0 6px 20px rgba(0,0,0,.25)}
      footer{border-top:1px solid #1f2a44;margin-top:56px}
      .btn{display:inline-block;padding:12px 16px;border-radius:12px;background:var(--accent);color:#222;font-weight:700}
      .btn:hover{filter:brightness(1.05)}
      .grid{display:grid;gap:16px}
      @media(min-width:800px){.grid-3{grid-template-columns:repeat(3,1fr)}.grid-2{grid-template-columns:repeat(2,1fr)}}
    </style>
  </head>
  <body>
    <header>
      <div class="wrap">
        <nav>
          <div class="brand">
            <img src="/favicon.svg" alt="FGI logo" width="28" height="28" />
            <a href="/"><span>Fountain of Grace International</span></a>
          </div>
          <div class="navlinks">
            <a href="/blog">Blog</a>
            <a href="/events">Events</a>
            <a href="/prayer">Prayer</a>
            <a href="/give" class="btn">Give</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer>
      <div class="wrap" style="display:flex;flex-wrap:wrap;gap:16px;align-items:center;justify-content:space-between;">
        <div>© {new Date().getFullYear()} Fountain of Grace International • Pretoria North</div>
        <div><a href="/contact">Contact</a> · <a href="/privacy">Privacy</a></div>
      </div>
    </footer>
  </body>
</html>
