# Public environment variables for fountaingrace.org
# These NEXT_PUBLIC_* values are baked into the client bundle at build time.
# They are NOT secrets, but never add private keys or service-role tokens here.

# Base URL for the Supabase Edge Functions that back the site's forms.
# Example: https://<project-ref>.supabase.co/functions/v1
NEXT_PUBLIC_SUPABASE_EDGE_BASE=

# Cloudflare Turnstile site key (public) used by the form anti-spam widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
